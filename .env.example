# Local development (MySQL)
DB_NAME=travelerschoice_db
DB_USER=root
DB_PASSWORD=your_mysql_password

# Session secret (use a long random string in production)
SESSION_SECRET=your_session_secret_here

# Heroku: JAWSDB_URL is set automatically when you add JawsDB MySQL add-on.
# SESSION_SECRET: set in Heroku Config Vars (Settings → Reveal Config Vars).
